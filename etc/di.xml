<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="PlaceholderTech\Klar\Api\DiscountServiceInterface" type="PlaceholderTech\Klar\Model\DiscountService"/>
    <preference for="PlaceholderTech\Klar\Api\Data\ApiInterface" type="PlaceholderTech\Klar\Model\Api"/>
    <preference for="PlaceholderTech\Klar\Api\Data\TaxInterface" type="PlaceholderTech\Klar\Model\Data\Tax"/>
    <preference for="PlaceholderTech\Klar\Api\Data\DiscountInterface" type="PlaceholderTech\Klar\Model\Data\Discount"/>
    <preference for="PlaceholderTech\Klar\Api\Data\LineItemInterface" type="PlaceholderTech\Klar\Model\Data\LineItem"/>
    <preference for="PlaceholderTech\Klar\Api\Data\RefundedLineItemInterface" type="PlaceholderTech\Klar\Model\Data\RefundedLineItem"/>
    <preference for="PlaceholderTech\Klar\Api\Data\OrderInterface" type="PlaceholderTech\Klar\Model\Data\Order"/>
    <preference for="PlaceholderTech\Klar\Api\Data\ShippingInterface" type="PlaceholderTech\Klar\Model\Data\Shipping"/>
    <preference for="PlaceholderTech\Klar\Api\Data\CustomerInterface" type="PlaceholderTech\Klar\Model\Data\Customer"/>
    <preference for="PlaceholderTech\Klar\Api\Data\OptionalIdentifiersInterface" type="PlaceholderTech\Klar\Model\Data\OptionalIdentifiers"/>
    <virtualType name="KlarLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="error" xsi:type="object">PlaceholderTech\Klar\Logger\Handler\KlarHandler</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="PlaceholderTech\Klar\Model\Api">
        <arguments>
            <argument name="logger" xsi:type="object">KlarLogger</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="KlarOrder" xsi:type="object">PlaceholderTech\Klar\Command\Order</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\MysqlMq\Model\Driver\Queue">
        <plugin name="queue_reject_plugin"
                type="PlaceholderTech\Klar\Plugin\QueueRejectPlugin"/>
    </type>
    <type name="Magento\Sales\Model\ResourceModel\Order\Grid\Collection">
        <plugin name="klar_order_grid_plugin"
                type="PlaceholderTech\Klar\Plugin\KlarOrderGridPlugin"/>
    </type>

    <!-- Klar field mapping config -->
    <type name="PlaceholderTech\Klar\Model\Config\FieldMapping\Reader">
        <arguments>
            <argument name="fileName" xsi:type="string">klar_field_mapping.xml</argument>
            <argument name="converter" xsi:type="object">PlaceholderTech\Klar\Model\Config\FieldMapping\Converter</argument>
            <argument name="schemaLocator" xsi:type="object">PlaceholderTech\Klar\Model\Config\FieldMapping\SchemaLocator</argument>
        </arguments>
    </type>
    <type name="PlaceholderTech\Klar\Model\Config\FieldMapping\Data">
        <arguments>
            <argument name="reader" xsi:type="object">PlaceholderTech\Klar\Model\Config\FieldMapping\Reader</argument>
            <argument name="cacheId" xsi:type="string">klar_field_mapping</argument>
        </arguments>
    </type>
    <type name="PlaceholderTech\Klar\Model\AttributeValueResolver">
        <arguments>
            <argument name="logger" xsi:type="object">KlarLogger</argument>
        </arguments>
    </type>
</config>
