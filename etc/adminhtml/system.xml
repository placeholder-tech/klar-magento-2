<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="klar" translate="label" sortOrder="100" showInDefault="1" showInStore="0" showInWebsite="0">
            <label>Klar</label>
            <tab>sales</tab>
            <resource>PlaceholderTech_Klar::configuration</resource>

            <group id="integration" translate="label" sortOrder="10" showInDefault="1" showInWebsite="0"
                   showInStore="0">
                <label>Integration</label>
                <frontend_model>PlaceholderTech\Klar\Block\Adminhtml\System\Config\IntegrationFieldset</frontend_model>
                <comment><![CDATA[Configure your Klar integration settings below.]]></comment>

                <field id="enabled" translate="label" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0"
                       type="select">
                    <label>Enabled</label>
                    <comment><![CDATA[Enable Klar integration.]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="api_url" translate="label" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0"
                       type="text">
                    <label>API URL</label>
                    <comment><![CDATA[API base URL in following format: https://example.com]]></comment>
                    <validate>required-entry no-whitespace</validate>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="api_version" translate="label" sortOrder="20" showInDefault="1" showInWebsite="0"
                       showInStore="0"
                       type="text">
                    <label>API Version</label>
                    <comment><![CDATA[API version (can be found in URL provided in Klar API documentation).]]></comment>
                    <validate>required-entry no-whitespace</validate>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="api_token" translate="label comment" type="obscure" sortOrder="30" showInDefault="1"
                       showInWebsite="0" showInStore="0">
                    <label>API Token</label>
                    <comment><![CDATA[API authorization (Bearer) token.]]></comment>
                    <validate>required-entry</validate>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="send_email" translate="label" sortOrder="31" showInDefault="1" showInWebsite="0" showInStore="0"
                       type="select">
                    <label>Send Email</label>
                    <comment><![CDATA[Enable if you want to submit the customer's email address.]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="public_key" translate="label comment" type="obscure" sortOrder="32" showInDefault="1"
                       showInWebsite="0" showInStore="0">
                    <label>Salt for E-Mail Hash</label>
                    <comment><![CDATA[Salt used for hashing the customer's email address. Contact Klar support to receive your salt.]]></comment>
                    <validate>required-entry no-whitespace</validate>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="batch_size" translate="label comment" sortOrder="33" showInDefault="1" showInWebsite="0" showInStore="0"
                       type="text">
                    <label>Batch Size</label>
                    <comment><![CDATA[Number of orders per API batch (1-1000). Default: 250.]]></comment>
                    <validate>required-entry validate-digits validate-digits-range digits-range-1-1000</validate>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="test_connection" translate="label" type="button" sortOrder="34" showInDefault="1">
                    <label>Connection</label>
                    <frontend_model>PlaceholderTech\Klar\Block\Adminhtml\System\Config\TestConnectionButton</frontend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="sync_now" translate="label" type="button" sortOrder="35" showInDefault="1">
                    <label>Synchronization</label>
                    <frontend_model>PlaceholderTech\Klar\Block\Adminhtml\System\Config\SyncButton</frontend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="orders_status" translate="label comment" type="obscure" sortOrder="40" showInDefault="1"
                       showInWebsite="0" showInStore="0">
                    <label>Sync Status</label>
                    <comment><![CDATA[Local synchronization status overview.]]></comment>
                    <frontend_model>PlaceholderTech\Klar\Block\Adminhtml\System\Config\OrdersStatus</frontend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="log_viewer" translate="label" type="text" sortOrder="50" showInDefault="1"
                       showInWebsite="0" showInStore="0">
                    <label>Recent Log</label>
                    <frontend_model>PlaceholderTech\Klar\Block\Adminhtml\System\Config\LogViewer</frontend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
