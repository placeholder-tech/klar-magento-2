<?php
$scriptString = <<<script
require(['jquery'], function(jQuery) {

    function showMessage(msg, isError) {
        var el = jQuery('#klar_sync_message');
        el.text(msg)
          .css({
              'display': 'block',
              'background': isError ? '#fff0f0' : '#f0fff0',
              'border': '1px solid ' + (isError ? '#cc0000' : '#006400'),
              'color': isError ? '#cc0000' : '#006400'
          });
        setTimeout(function() { el.fadeOut(); }, 8000);
    }

    function syncRequest(url, data, btn) {
        var originalLabel = btn.find('span').text();
        btn.find('span').text('Processing...');
        btn.prop('disabled', true);

        jQuery.ajax({
            url: url,
            type: 'POST',
            dataType: 'json',
            data: jQuery.extend({form_key: window.FORM_KEY}, data || {}),
            success: function(response) {
                showMessage(response.message || 'Done', !response.success);
            },
            error: function(xhr) {
                showMessage('Request failed: ' + xhr.statusText, true);
            },
            complete: function() {
                btn.find('span').text(originalLabel);
                btn.prop('disabled', false);
            }
        });
    }

    // Sync All
    jQuery('#klar_sync_all').click(function() {
        if (!confirm('This will re-sync all {$totalOrders} orders to Klar. Are you sure?')) return;
        syncRequest('{$block->escapeJs($block->getSyncAllUrl())}', {}, jQuery(this));
    });

    // Sync Date Range
    jQuery('#klar_sync_range').click(function() {
        var from = jQuery('#klar_sync_from').val();
        var to = jQuery('#klar_sync_to').val();
        if (!from && !to) {
            showMessage('Please select at least a start or end date.', true);
            return;
        }
        syncRequest('{$block->escapeJs($block->getSyncRangeUrl())}', {from: from, to: to}, jQuery(this));
    });

    // Sync Single Order
    jQuery('#klar_sync_order').click(function() {
        var orderId = jQuery('#klar_sync_order_id').val().trim();
        if (!orderId) {
            showMessage('Please enter an order ID.', true);
            return;
        }
        syncRequest('{$block->escapeJs($block->getSyncOrderUrl())}', {order_id: orderId}, jQuery(this));
    });

    // Re-sync Failed
    jQuery('#klar_sync_failed').click(function() {
        syncRequest('{$block->escapeJs($block->getSyncFailedUrl())}', {}, jQuery(this));
    });

    // Preview JSON
    jQuery('#klar_preview_order').click(function() {
        var orderId = jQuery('#klar_sync_order_id').val().trim();
        if (!orderId) {
            showMessage('Please enter an order ID.', true);
            return;
        }
        var btn = jQuery(this);
        btn.find('span').text('Loading...');
        btn.prop('disabled', true);

        jQuery.ajax({
            url: '{$block->escapeJs($block->getPreviewUrl())}',
            type: 'POST',
            dataType: 'json',
            data: {form_key: window.FORM_KEY, order_id: orderId},
            success: function(response) {
                if (response.success) {
                    try {
                        var formatted = JSON.stringify(JSON.parse(response.json), null, 2);
                        jQuery('#klar_preview_json').text(formatted);
                    } catch(e) {
                        jQuery('#klar_preview_json').text(response.json);
                    }
                    jQuery('#klar_preview_area').show();
                } else {
                    showMessage(response.message || 'Preview failed', true);
                }
            },
            error: function(xhr) {
                showMessage('Request failed: ' + xhr.statusText, true);
            },
            complete: function() {
                btn.find('span').text('Preview JSON');
                btn.prop('disabled', false);
            }
        });
    });
});
script;
?>
<?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false) ?>
